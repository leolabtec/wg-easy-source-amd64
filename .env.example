# Default tracks the automated weekly amd64 build.
# For a pinned deployment, set this to a release tag such as:
# WG_EASY_IMAGE=ghcr.io/leolabtec/wg-easy-source-amd64:source-78b2838-amd64
WG_EASY_IMAGE=ghcr.io/leolabtec/wg-easy-source-amd64:latest-amd64

# Set this to the server's LAN IP, not its public IP.
# Example: LAN_BIND_IP=192.168.1.10
LAN_BIND_IP=192.168.1.10
